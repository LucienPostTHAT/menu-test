-- FLIGHT
local function stopFlying()
	flying = false
	flyButton.Text = "Fly: OFF"
	flyButton.BackgroundColor3 = COLORS.Button

	if flyConnection then
		flyConnection:Disconnect()
		flyConnection = nil
	end

	if bodyVelocity then
		bodyVelocity:Destroy()
		bodyVelocity = nil
	end

	if bodyGyro then
		bodyGyro:Destroy()
		bodyGyro = nil
	end

	if humanoid then
		humanoid.PlatformStand = false
	end
end

local function startFlying()
	updateCharacterReferences()
	if not humanoid or not rootPart then return end

	flying = true
	flyButton.Text = "Fly: ON"
	flyButton.BackgroundColor3 = COLORS.AccentDark

	bodyVelocity = Instance.new("BodyVelocity")
	bodyVelocity.MaxForce = Vector3.new(1e9, 1e9, 1e9)
	bodyVelocity.Velocity = Vector3.zero
	bodyVelocity.Parent = rootPart

	bodyGyro = Instance.new("BodyGyro")
	bodyGyro.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
	bodyGyro.P = 10000
	bodyGyro.CFrame = rootPart.CFrame
	bodyGyro.Parent = rootPart

	humanoid.PlatformStand = true

	flyConnection = RunService.RenderStepped:Connect(function()
		updateCharacterReferences()

		if not flying or not rootPart or not camera then
			stopFlying()
			return
		end

		local moveDirection = Vector3.zero

		if keys.W then moveDirection += camera.CFrame.LookVector end
		if keys.S then moveDirection -= camera.CFrame.LookVector end
		if keys.A then moveDirection -= camera.CFrame.RightVector end
		if keys.D then moveDirection += camera.CFrame.RightVector end
		if keys.Space then moveDirection += Vector3.new(0, 1, 0) end
		if keys.Shift then moveDirection -= Vector3.new(0, 1, 0) end

		if moveDirection.Magnitude > 0 then
			moveDirection = moveDirection.Unit
		end

		bodyVelocity.Velocity = moveDirection * flySpeed
		bodyGyro.CFrame = camera.CFrame
	end)
end

local function toggleFlight()
	if flying then
		stopFlying()
	else
		startFlying()
	end
end

flyButton.MouseButton1Click:Connect(toggleFlight)

plusButton.MouseButton1Click:Connect(function()
	flySpeed += 10
	if flySpeed > 200 then flySpeed = 200 end
	speedLabel.Text = "Flight Speed: " .. flySpeed
end)

minusButton.MouseButton1Click:Connect(function()
	flySpeed -= 10
	if flySpeed < 10 then flySpeed = 10 end
	speedLabel.Text = "Flight Speed: " .. flySpeed
end)

-- TAGS
local function removeTag(targetPlayer)
	local data = trackedTags[targetPlayer]
	if not data then return end

	if data.billboard then
		data.billboard:Destroy()
	end

	trackedTags[targetPlayer] = nil
end

local function createTag(targetPlayer, targetCharacter)
	if targetPlayer == player then return end
	if not targetCharacter then return end

	local head = targetCharacter:FindFirstChild("Head")
	local hrp = targetCharacter:FindFirstChild("HumanoidRootPart")
	local hum = targetCharacter:FindFirstChildOfClass("Humanoid")

	if not head or not hrp or not hum then return end

	removeTag(targetPlayer)

	local billboard = Instance.new("BillboardGui")
	billboard.Name = "LucienTag"
	billboard.Size = UDim2.new(0, 105, 0, 26)
	billboard.StudsOffset = Vector3.new(0, 3.8, 0)
	billboard.AlwaysOnTop = true
	billboard.MaxDistance = 220
	billboard.Adornee = head
	billboard.Parent = playerGui

	local bg = Instance.new("Frame")
	bg.Size = UDim2.new(1, 0, 1, 0)
	bg.BackgroundColor3 = COLORS.Top
	bg.BackgroundTransparency = 0.2
	bg.BorderSizePixel = 0
	bg.Parent = billboard

	local bgStroke = Instance.new("UIStroke")
	bgStroke.Color = COLORS.Line
	bgStroke.Thickness = 1
	bgStroke.Parent = bg

	local nameLabel = Instance.new("TextLabel")
	nameLabel.BackgroundTransparency = 1
	nameLabel.Size = UDim2.new(1, -6, 0.55, 0)
	nameLabel.Position = UDim2.new(0, 3, 0, 0)
	nameLabel.Text = targetPlayer.DisplayName
	nameLabel.TextColor3 = COLORS.Text
	nameLabel.TextSize = 10
	nameLabel.Font = Enum.Font.GothamBold
	nameLabel.TextWrapped = true
	nameLabel.Parent = bg

	local distanceLabel = Instance.new("TextLabel")
	distanceLabel.BackgroundTransparency = 1
	distanceLabel.Size = UDim2.new(1, -6, 0.45, 0)
	distanceLabel.Position = UDim2.new(0, 3, 0.5, 0)
	distanceLabel.Text = "0 studs"
	distanceLabel.TextColor3 = COLORS.SubText
	distanceLabel.TextSize = 9
	distanceLabel.Font = Enum.Font.Gotham
	distanceLabel.Parent = bg

	trackedTags[targetPlayer] = {
		character = targetCharacter,
		head = head,
		hrp = hrp,
		humanoid = hum,
		billboard = billboard,
		nameLabel = nameLabel,
		distanceLabel = distanceLabel
	}
end

local function refreshPlayerTag(targetPlayer)
	if targetPlayer == player then return end
	if not tagsEnabled then
		removeTag(targetPlayer)
		return
	end

	local targetCharacter = targetPlayer.Character
	if not targetCharacter then
		removeTag(targetPlayer)
		return
	end

	createTag(targetPlayer, targetCharacter)
end

local function setupTagPlayer(targetPlayer)
	if targetPlayer == player then return end

	targetPlayer.CharacterAdded:Connect(function(newCharacter)
		task.wait(0.2)
		if tagsEnabled then
			createTag(targetPlayer, newCharacter)
		end
	end)

	targetPlayer.CharacterRemoving:Connect(function()
		removeTag(targetPlayer)
	end)

	if targetPlayer.Character and tagsEnabled then
		createTag(targetPlayer, targetPlayer.Character)
	end
end

for _, otherPlayer in ipairs(Players:GetPlayers()) do
	setupTagPlayer(otherPlayer)
end

Players.PlayerAdded:Connect(setupTagPlayer)
Players.PlayerRemoving:Connect(function(leavingPlayer)
	removeTag(leavingPlayer)
end)

local function setTagsEnabled(state)
	tagsEnabled = state
	tagsButton.Text = state and "Tags: ON" or "Tags: OFF"
	tagsButton.BackgroundColor3 = state and COLORS.AccentDark or COLORS.Button

	if not state then
		for targetPlayer in pairs(trackedTags) do
			removeTag(targetPlayer)
		end
	else
		for _, otherPlayer in ipairs(Players:GetPlayers()) do
			if otherPlayer ~= player then
				refreshPlayerTag(otherPlayer)
			end
		end
	end
end

tagsButton.MouseButton1Click:Connect(function()
	setTagsEnabled(not tagsEnabled)
end)

RunService.RenderStepped:Connect(function()
	if not tagsEnabled then return end
	if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end

	local myRoot = player.Character.HumanoidRootPart

	for targetPlayer, data in pairs(trackedTags) do
		local targetCharacter = data.character

		if not targetCharacter or not targetCharacter.Parent then
			removeTag(targetPlayer)
		else
			local currentHRP = targetCharacter:FindFirstChild("HumanoidRootPart")
			local currentHead = targetCharacter:FindFirstChild("Head")
			local currentHum = targetCharacter:FindFirstChildOfClass("Humanoid")

			if not currentHRP or not currentHead or not currentHum or currentHum.Health <= 0 then
				removeTag(targetPlayer)
			else
				local distance = (currentHRP.Position - myRoot.Position).Magnitude
				data.distanceLabel.Text = showDistance and (math.floor(distance) .. " studs") or ""

				local screenPoint, onScreen = camera:WorldToViewportPoint(currentHead.Position)
				data.billboard.Enabled = onScreen and distance <= 220
			end
		end
	end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end

	if input.KeyCode == Enum.KeyCode.W then keys.W = true end
	if input.KeyCode == Enum.KeyCode.A then keys.A = true end
	if input.KeyCode == Enum.KeyCode.S then keys.S = true end
	if input.KeyCode == Enum.KeyCode.D then keys.D = true end
	if input.KeyCode == Enum.KeyCode.Space then keys.Space = true end
	if input.KeyCode == Enum.KeyCode.LeftShift or input.KeyCode == Enum.KeyCode.RightShift then
		keys.Shift = true
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.KeyCode == Enum.KeyCode.W then keys.W = false end
	if input.KeyCode == Enum.KeyCode.A then keys.A = false end
	if input.KeyCode == Enum.KeyCode.S then keys.S = false end
	if input.KeyCode == Enum.KeyCode.D then keys.D = false end
	if input.KeyCode == Enum.KeyCode.Space then keys.Space = false end
	if input.KeyCode == Enum.KeyCode.LeftShift or input.KeyCode == Enum.KeyCode.RightShift then
		keys.Shift = false
	end
end)
